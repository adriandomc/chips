# SwiftFormat config — alineado con SwiftLint strict.

--swiftversion 6.0
--indent 4
--maxwidth 140
--tabwidth 4
--linebreaks lf
--allman false
--commas always
--semicolons never
--trimwhitespace always
--ifdef no-indent
--xcodeindentation enabled
--wraparguments before-first
--wrapparameters before-first
--wrapcollections before-first
--wrapconditions before-first
--wrapreturntype if-multiline
--wrapternary before-operators
--closingparen balanced
--funcattributes prev-line
--typeattributes prev-line
--varattributes same-line
--decimalgrouping 3,4
--binarygrouping 4,8
--octalgrouping 4,8
--hexgrouping 4,8
--hexliteralcase uppercase
--exponentcase lowercase
--patternlet hoist
--self init-only
--selfrequired
--stripunusedargs closure-only
--header strip
--marktypes always
--markextensions always

--enable redundantSelf
--enable redundantReturn
--enable redundantParens
--enable redundantBackticks
--enable redundantBreak
--enable redundantClosure
--enable redundantExtensionACL
--enable redundantFileprivate
--enable redundantGet
--enable redundantInit
--enable redundantInternal
--enable redundantLet
--enable redundantLetError
--enable redundantNilInit
--enable redundantObjc
--enable redundantOptionalBinding
--enable redundantPattern
--enable redundantRawValues
--enable redundantType
--enable redundantTypedThrows
--enable redundantVoidReturnType
--enable sortImports
--enable sortDeclarations
--enable strongifiedSelf
--enable trailingCommas
--enable wrapMultilineStatementBraces
--enable blankLineAfterImports
--enable blankLinesBetweenScopes

--disable wrapMultilineStatementBraces
--exclude .build,.swiftpm,Packages/*/.build,Packages/*/.swiftpm,fastlane
